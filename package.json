{
  "name": "bore",
  "version": "1.0.0",
  "description": "BORE - AI-powered development task orchestration",
  "main": "electron-dist/main.js",
  "scripts": {
    "dev:web": "concurrently -k -n \"go,vite\" -c \"cyan,magenta\" \"go run ./cmd/bore-server\" \"cd frontend && npm run dev\"",
    "dev": "npm run build:frontend && npm run build:go && npm run build:electron && NODE_ENV=development electron .",
    "build:go": "go build -o bore-server ./cmd/bore-server",
    "build:frontend": "cd frontend && npm install && npm run build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:all": "npm run build:frontend && npm run build:go && npm run build:electron",
    "start": "npm run build:electron && electron .",
    "dist": "npm run build:all && electron-builder"
  },
  "build": {
    "appId": "com.bore.app",
    "productName": "BORE",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron-dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "bore-server",
        "to": "bore-server"
      },
      {
        "from": "bore-server.exe",
        "to": "bore-server.exe"
      }
    ],
    "mac": {
      "target": [{"target": "dmg", "arch": ["arm64", "x64"]}],
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": [{"target": "nsis", "arch": ["x64"]}],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "~5.9.3"
  }
}
